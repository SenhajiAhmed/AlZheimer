# Copy this file to .env and fill in your keys. Never commit .env to git.

# ── LLM APIs ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ── Choose LLM backend: "openai" or "groq" ────────────────────────────────
LLM_BACKEND=groq
LLM_MODEL=llama3-70b-8192        # Groq model, or gpt-4o for OpenAI

# ── Model config ──────────────────────────────────────────────────────────
VISION_BACKBONE=vit               # "vit" or "resnet"
BATCH_SIZE=16
DEVICE=cuda                       # "cuda" or "cpu"
